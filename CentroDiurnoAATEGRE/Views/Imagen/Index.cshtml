@{
    ViewData["Title"] = "Gestión de Galería";
}

<div class="panel-header">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
                <h1 class="mb-1"><i class="bi bi-images me-2"></i>Gestión de Galería</h1>
                <p class="mb-0">Sube y organiza las imágenes que aparecerán en el sitio público.</p>
            </div>
            <div class="d-flex gap-2 flex-wrap">
                <a asp-controller="Home" asp-action="Dashboard" class="btn-secundario"
                   style="border-color:rgba(255,255,255,0.5);color:white;">
                    <i class="bi bi-arrow-left"></i>Panel
                </a>
                <a asp-controller="CategoriaImagen" asp-action="Index" class="btn-secundario"
                   style="border-color:rgba(255,255,255,0.5);color:white;">
                    <i class="bi bi-folder2"></i>Categorías
                </a>
                <a asp-action="Crear" class="btn-primario" style="background:white;color:var(--azul);">
                    <i class="bi bi-plus-circle-fill"></i>Agregar Imagen
                </a>
            </div>
        </div>
    </div>
</div>

<div class="container py-4">
    @if (TempData["Exito"] != null)
    {
        <div class="alert alert-success d-flex align-items-center gap-2 rounded-3 mb-4">
            <i class="bi bi-check-circle-fill"></i> @TempData["Exito"]
        </div>
    }

    @if (Model != null && ((IEnumerable<dynamic>)Model).Any())
    {
        <div class="row g-3">
            @foreach (var img in Model)
            {
                <div class="col-sm-6 col-md-4 col-lg-3">
                    <div class="bg-white rounded-3 shadow-sm overflow-hidden h-100">
                        <div style="height:180px;background:var(--gris);overflow:hidden;position:relative;">
                            @if (!string.IsNullOrEmpty(img.RutaArchivo))
                            {
                                <img src="~/uploads/@img.RutaArchivo" alt="@img.Titulo"
                                     style="width:100%;height:100%;object-fit:cover;" />
                            }
                            else
                            {
                                <div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;flex-direction:column;gap:.5rem;color:var(--texto-suave);">
                                    <i class="bi bi-image" style="font-size:2.5rem;color:var(--gris-borde);"></i>
                                    <small>Sin imagen</small>
                                </div>
                            }
                            <span style="position:absolute;top:.5rem;left:.5rem;background:rgba(43,108,184,.85);color:white;padding:.2rem .65rem;border-radius:50px;font-size:.72rem;font-weight:600;">
                                <i class="bi bi-folder-fill me-1"></i>@img.CategoriaImagen?.Nombre
                            </span>
                        </div>
                        <div class="p-3">
                            <h6 class="fw-bold mb-1" style="font-family:'Playfair Display',serif;font-size:.95rem;">@img.Titulo</h6>
                            <div class="text-muted" style="font-size:.78rem;">
                                <i class="bi bi-calendar3 me-1"></i>@img.FechaImagen.ToString("dd/MM/yyyy")
                            </div>
                            <div class="d-flex gap-2 mt-3">
                                <a asp-action="Editar" asp-route-id="@img.IdImagen"
                                   class="btn btn-sm btn-outline-primary rounded-2 flex-fill text-center">
                                    <i class="bi bi-pencil me-1"></i>Editar
                                </a>
                                <a asp-action="Eliminar" asp-route-id="@img.IdImagen"
                                   class="btn btn-sm btn-outline-danger rounded-2"
                                   onclick="return confirm('¿Eliminar esta imagen?')">
                                    <i class="bi bi-trash"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <i class="bi bi-images" style="font-size:4rem;color:var(--gris-borde);"></i>
            <h5 class="mt-3" style="color:var(--texto-suave);">La galería está vacía</h5>
            <a asp-action="Crear" class="btn-primario mt-2"><i class="bi bi-plus-circle"></i>Agregar primera imagen</a>
        </div>
    }
</div>