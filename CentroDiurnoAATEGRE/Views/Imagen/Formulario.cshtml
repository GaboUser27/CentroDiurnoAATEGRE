@using CentroDiurnoAATEGRE.Application.DTOs
@model ImagenDTO
@{
    bool esEdicion = Model.IdImagen > 0;
    ViewData["Title"] = esEdicion ? "Editar Imagen" : "Agregar Imagen";
}

<div class="panel-header">
    <div class="container">
        <div class="d-flex align-items-center gap-3">
            <a asp-action="Index" class="btn-secundario"
               style="border-color:rgba(255,255,255,0.5);color:white;">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 class="mb-0">
                <i class="bi bi-@(esEdicion ? "pencil-square" : "image") me-2"></i>@ViewData["Title"]
            </h1>
        </div>
    </div>
</div>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="bg-white rounded-3 shadow-sm p-4 p-md-5">
                @if (esEdicion && Model.ImagenBase64 != null)
                {
                    <div class="mb-4 text-center">
                        <p class="form-label">Imagen actual</p>
                        <img src="@Model.ImagenBase64" alt="Imagen actual"
                             style="max-height:200px;border-radius:12px;box-shadow:var(--sombra);" />
                    </div>
                }
                <form method="post" enctype="multipart/form-data"
                      asp-action="@(esEdicion ? "Editar" : "Crear")"
                      asp-route-id="@Model.IdImagen" class="form-admin">
                    @Html.AntiForgeryToken()
                    <div class="mb-4">
                        <label class="form-label" for="archivo">
                            <i class="bi bi-cloud-upload me-1"></i>
                            @(esEdicion ? "Reemplazar imagen (opcional)" : "Imagen *")
                        </label>
                        <input type="file" id="archivo" name="archivo" class="form-control"
                               accept="image/*" @(!esEdicion ? "required" : "")
                               onchange="previsualizarImagen(this)" />
                        <div id="previewWrap" class="mt-3 text-center" style="display:none;">
                            <img id="previewImg" src="" alt="Vista previa"
                                 style="max-height:220px;border-radius:12px;box-shadow:var(--sombra);" />
                        </div>
                        <small class="text-muted">Formatos: JPG, PNG, WebP, GIF.</small>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="Titulo">
                            <i class="bi bi-fonts me-1"></i>Título
                        </label>
                        <input asp-for="Titulo" class="form-control"
                               placeholder="Ej: Taller de manualidades" maxlength="150" required />
                        <span asp-validation-for="Titulo" class="text-danger small"></span>
                    </div>
                    <div class="mb-3">
                        <label class="form-label" asp-for="Descripcion">
                            <i class="bi bi-text-paragraph me-1"></i>Descripción
                            <span class="text-muted fw-normal">(opcional)</span>
                        </label>
                        <textarea asp-for="Descripcion" class="form-control" rows="3"
                                  placeholder="Breve descripción..."></textarea>
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col-md-7">
                            <label class="form-label" asp-for="IdCategoriaImagen">
                                <i class="bi bi-folder me-1"></i>Categoría
                            </label>
                            <select asp-for="IdCategoriaImagen" asp-items="ViewBag.Categorias"
                                    class="form-select" required>
                                <option value="">— Seleccione —</option>
                            </select>
                            <span asp-validation-for="IdCategoriaImagen" class="text-danger small"></span>
                        </div>
                        <div class="col-md-5">
                            <label class="form-label" asp-for="FechaImagen">
                                <i class="bi bi-calendar3 me-1"></i>Fecha
                            </label>
                            <input asp-for="FechaImagen" type="date" class="form-control" required />
                        </div>
                    </div>
                    <div class="d-flex gap-3 justify-content-end">
                        <a asp-action="Index" class="btn-secundario">
                            <i class="bi bi-x-circle"></i>Cancelar
                        </a>
                        <button type="submit" class="btn-primario">
                            <i class="bi bi-@(esEdicion ? "check-circle" : "upload")"></i>
                            @(esEdicion ? "Guardar cambios" : "Subir imagen")
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function previsualizarImagen(input) {
            const wrap = document.getElementById('previewWrap');
            const img  = document.getElementById('previewImg');
            if (input.files && input.files[0]) {
                const reader = new FileReader();
                reader.onload = e => { img.src = e.target.result; wrap.style.display = 'block'; };
                reader.readAsDataURL(input.files[0]);
            }
        }
    </script>
}