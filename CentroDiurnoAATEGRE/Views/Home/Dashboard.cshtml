@{
    ViewData["Title"] = "Panel Administrativo";
}

<div class="panel-header">
    <div class="container">
        <div class="d-flex align-items-center justify-content-between flex-wrap gap-3">
            <div>
                <h1 class="mb-1"><i class="bi bi-grid-1x2 me-2"></i>Panel Administrativo</h1>
                <p class="mb-0">Bienvenido/a, <strong>@User.Identity?.Name</strong>.</p>
            </div>
            <a asp-controller="Home" asp-action="Index" class="btn-secundario"
               style="border-color:rgba(255,255,255,0.5); color:white;">
                <i class="bi bi-eye"></i>Ver sitio
            </a>
        </div>
    </div>
</div>

<div class="container py-4">
    <div class="row g-4 mb-5">
        <div class="col-sm-6 col-lg-3">
            <div class="stat-card azul">
                <div class="stat-num" style="color:var(--azul)">@(ViewBag.TotalAvisos ?? 0)</div>
                <div class="stat-label">Avisos activos</div>
                <i class="bi bi-megaphone-fill mt-2" style="color:var(--azul);font-size:1.4rem;opacity:.4;"></i>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="stat-card lila">
                <div class="stat-num" style="color:var(--lila)">@(ViewBag.TotalImagenes ?? 0)</div>
                <div class="stat-label">Imágenes en galería</div>
                <i class="bi bi-images mt-2" style="color:var(--lila);font-size:1.4rem;opacity:.4;"></i>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="stat-card verde">
                <div class="stat-num" style="color:#2E7D32">@(ViewBag.TotalCategorias ?? 0)</div>
                <div class="stat-label">Categorías de galería</div>
                <i class="bi bi-folder-fill mt-2" style="color:#2E7D32;font-size:1.4rem;opacity:.4;"></i>
            </div>
        </div>
        <div class="col-sm-6 col-lg-3">
            <div class="stat-card naranja">
                <div class="stat-num" style="color:#E65100">@(ViewBag.TotalUsuarios ?? 0)</div>
                <div class="stat-label">Usuarios del sistema</div>
                <i class="bi bi-people-fill mt-2" style="color:#E65100;font-size:1.4rem;opacity:.4;"></i>
            </div>
        </div>
    </div>

    <h5 class="mb-3" style="font-family:'Playfair Display',serif;color:var(--azul-oscuro);">Gestión de contenido</h5>
    <div class="row g-3 mb-5">
        <div class="col-sm-6 col-md-4 col-lg-3">
            <a asp-controller="Aviso" asp-action="Index" class="servicio-card d-block text-decoration-none">
                <div class="servicio-icono-wrap servicio-icono-azul mx-auto"><i class="bi bi-megaphone-fill"></i></div>
                <h5 class="servicio-titulo">Avisos</h5>
                <p class="servicio-desc">Crear y administrar comunicados con fecha de expiración.</p>
            </a>
        </div>
        <div class="col-sm-6 col-md-4 col-lg-3">
            <a asp-controller="Imagen" asp-action="Index" class="servicio-card d-block text-decoration-none">
                <div class="servicio-icono-wrap servicio-icono-lila mx-auto"><i class="bi bi-images"></i></div>
                <h5 class="servicio-titulo">Galería</h5>
                <p class="servicio-desc">Gestionar imágenes y categorías de actividades.</p>
            </a>
        </div>
        <div class="col-sm-6 col-md-4 col-lg-3">
            <a asp-controller="InformacionInstitucional" asp-action="Index" class="servicio-card d-block text-decoration-none">
                <div class="servicio-icono-wrap servicio-icono-verde mx-auto"><i class="bi bi-building-fill"></i></div>
                <h5 class="servicio-titulo">Información del Centro</h5>
                <p class="servicio-desc">Actualizar datos institucionales, contacto y redes sociales.</p>
            </a>
        </div>
        <div class="col-sm-6 col-md-4 col-lg-3">
            <a asp-controller="Usuario" asp-action="Index" class="servicio-card d-block text-decoration-none">
                <div class="servicio-icono-wrap servicio-icono-naranja mx-auto"><i class="bi bi-people-fill"></i></div>
                <h5 class="servicio-titulo">Usuarios</h5>
                <p class="servicio-desc">Crear, activar o desactivar cuentas de funcionarios.</p>
            </a>
        </div>
    </div>

    <div class="row g-4">
        <div class="col-lg-7">
            <div class="bg-white rounded-3 shadow-sm p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0" style="font-family:'Playfair Display',serif;color:var(--azul-oscuro);">
                        <i class="bi bi-megaphone me-2 text-primary"></i>Avisos Recientes
                    </h5>
                    <a asp-controller="Aviso" asp-action="Crear" class="btn-primario" style="padding:.5rem 1rem;font-size:.88rem;">
                        <i class="bi bi-plus-lg"></i>Nuevo
                    </a>
                </div>
                <div class="table-responsive">
                    <table class="tabla-admin">
                        <thead>
                            <tr><th>Título</th><th>Publicación</th><th>Estado</th><th></th></tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.AvisosRecientes != null)
                            {
                                foreach (var a in ViewBag.AvisosRecientes)
                                {
                                    <tr>
                                        <td class="fw-semibold">@a.Titulo</td>
                                        <td>@a.FechaPublicacion.ToString("dd/MM/yy")</td>
                                        <td>
                                            @if (a.Activo)
                                            {
                                                <span class="badge-vigente">Activo</span>
                                            }
                                            else
                                            {
                                                <span class="badge-expirado">Inactivo</span>
                                            }
                                        </td>
                                        <td>
                                            <a asp-controller="Aviso" asp-action="Editar" asp-route-id="@a.IdAviso"
                                               class="btn btn-sm btn-outline-primary rounded-2">
                                                <i class="bi bi-pencil"></i>
                                            </a>
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="4" class="text-center text-muted py-3">No hay avisos aún.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
        <div class="col-lg-5">
            <div class="bg-white rounded-3 shadow-sm p-4">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0" style="font-family:'Playfair Display',serif;color:var(--azul-oscuro);">
                        <i class="bi bi-people me-2 text-warning"></i>Usuarios
                    </h5>
                    <a asp-controller="Usuario" asp-action="Crear" class="btn-primario" style="padding:.5rem 1rem;font-size:.88rem;">
                        <i class="bi bi-plus-lg"></i>Nuevo
                    </a>
                </div>
                <div class="table-responsive">
                    <table class="tabla-admin">
                        <thead>
                            <tr><th>Nombre</th><th>Rol</th><th>Estado</th></tr>
                        </thead>
                        <tbody>
                            @if (ViewBag.Usuarios != null)
                            {
                                foreach (var u in ViewBag.Usuarios)
                                {
                                    <tr>
                                        <td class="fw-semibold">@u.Nombre</td>
                                        <td><small>@u.Rol?.Nombre</small></td>
                                        <td>
                                            @if (u.EstadoUsuario?.Nombre == "Activo")
                                            {
                                                <span class="badge-activo">Activo</span>
                                            }
                                            else
                                            {
                                                <span class="badge-inactivo">Inactivo</span>
                                            }
                                        </td>
                                    </tr>
                                }
                            }
                            else
                            {
                                <tr><td colspan="3" class="text-center text-muted py-3">No hay usuarios.</td></tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>