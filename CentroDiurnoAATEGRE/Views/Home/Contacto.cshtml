@{
    ViewData["Title"] = "Contacto";
    ViewData["ActivePage"] = "Contacto";
    var info = ViewBag.Informacion;
}

<div style="background:linear-gradient(135deg,var(--azul-oscuro),var(--azul));padding:5rem 0 4rem;position:relative;overflow:hidden;">
    <div style="position:absolute;bottom:0;left:0;right:0;height:60px;background:white;clip-path:ellipse(55% 100% at 50% 100%);"></div>
    <div class="container text-center position-relative">
        <div class="hero-eyebrow d-inline-flex mb-3">
            <i class="bi bi-envelope-heart me-2"></i>Estamos aquí para ayudarle
        </div>
        <h1 style="font-family:'Playfair Display',serif;color:white;font-size:clamp(1.8rem,4vw,2.8rem);">
            Información de Contacto
        </h1>
    </div>
</div>

<section style="padding:5rem 0;background:var(--blanco);">
    <div class="container">
        <div class="row g-5 align-items-start">
            <div class="col-lg-5">
                <h2 class="seccion-titulo">Visítenos o escríbanos</h2>
                <div class="linea-acento izquierda mb-4"></div>
                <div class="d-flex flex-column gap-3 mt-4">
                    <div class="contacto-card">
                        <div class="contacto-icono ci-azul"><i class="bi bi-geo-alt-fill"></i></div>
                        <div>
                            <p class="contacto-info-titulo">Dirección</p>
                            <p class="contacto-info-dato">@(info?.Direccion ?? "Grecia, Alajuela, Costa Rica")</p>
                        </div>
                    </div>
                    <div class="contacto-card">
                        <div class="contacto-icono ci-lila"><i class="bi bi-telephone-fill"></i></div>
                        <div>
                            <p class="contacto-info-titulo">Teléfono</p>
                            <p class="contacto-info-dato">
                                <a href="tel:@(info?.Telefono ?? "")" style="color:var(--texto-suave);">
                                    @(info?.Telefono ?? "+506 2494-XXXX")
                                </a>
                            </p>
                        </div>
                    </div>
                    <div class="contacto-card">
                        <div class="contacto-icono ci-verde"><i class="bi bi-envelope-fill"></i></div>
                        <div>
                            <p class="contacto-info-titulo">Correo electrónico</p>
                            <p class="contacto-info-dato">
                                <a href="mailto:@(info?.Correo ?? "info@aategre.cr")" style="color:var(--texto-suave);">
                                    @(info?.Correo ?? "info@aategre.cr")
                                </a>
                            </p>
                        </div>
                    </div>
                    <div class="contacto-card">
                        <div class="contacto-icono ci-naranja"><i class="bi bi-clock-fill"></i></div>
                        <div>
                            <p class="contacto-info-titulo">Horario de atención</p>
                            <p class="contacto-info-dato">Lunes a Viernes · 8:00 a.m. – :00 p.m.</p>
                        </div>
                    </div>
                </div>
                @if (info?.Facebook != null || info?.Instagram != null)
                {
                    <div class="mt-4 d-flex gap-2 flex-wrap">
                        @if (!string.IsNullOrEmpty(info?.Facebook))
                        {
                            <a href="@info.Facebook" target="_blank" rel="noopener" class="rrss-btn fb">
                                <i class="bi bi-facebook"></i>Facebook
                            </a>
                        }
                        @if (!string.IsNullOrEmpty(info?.Instagram))
                        {
                            <a href="@info.Instagram" target="_blank" rel="noopener" class="rrss-btn ig">
                                <i class="bi bi-instagram"></i>Instagram
                            </a>
                        }
                    </div>
                }
            </div>
            <div class="col-lg-7">
                <div class="rounded-4 shadow-sm overflow-hidden" style="height: 420px;">
                    <iframe width="100%"
                            height="100%"
                            frameborder="0"
                            scrolling="no"
                            marginheight="0"
                            marginwidth="0"
                            src="https://maps.google.com/maps?q=Centro+Diurno+AATEGRE,+Costa+Rica&t=&z=16&ie=UTF8&iwloc=&output=embed"
                            style="border: 0;"
                            allowfullscreen=""
                            loading="lazy"
                            referrerpolicy="no-referrer-when-downgrade">
                    </iframe>
                </div>
            </div>
        </div>
    </div>
</section>