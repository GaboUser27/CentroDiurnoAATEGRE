<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — AATEGRE Centro Diurno</title>
    <meta name="description" content="AATEGRE Centro Diurno — Cuidado integral y calidez humana para adultos mayores en Grecia, Alajuela." />

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Lato:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="icon" type="image/png" href="~/img/logo_AATEGRE.png" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-aategre">
        <div class="container">
            <a class="navbar-brand d-flex align-items-center gap-2" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo AATEGRE.png" alt="Logo AATEGRE" />
                <div class="brand-text">
                    <span class="brand-nombre">AATEGRE</span>
                    <span class="brand-subtitulo">Centro Diurno</span>
                </div>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse"
                    data-bs-target="#navbarMain" aria-label="Abrir menú">
                <i class="bi bi-list fs-2 text-primary"></i>
            </button>

            <div class="collapse navbar-collapse" id="navbarMain">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Index" ? "active" : "")"
                           asp-controller="Home" asp-action="Index">
                            <i class="bi bi-house-heart me-1"></i>Inicio
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Quienes" ? "active" : "")"
                           asp-controller="Home" asp-action="QuienesSomos">
                            <i class="bi bi-people me-1"></i>Quiénes Somos
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Actividades" ? "active" : "")"
                           asp-controller="Imagen" asp-action="Galeria">
                            <i class="bi bi-images me-1"></i>Actividades
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link @(ViewData["ActivePage"]?.ToString() == "Contacto" ? "active" : "")"
                           asp-controller="Home" asp-action="Contacto">
                            <i class="bi bi-envelope-heart me-1"></i>Contacto
                        </a>
                    </li>
                    <li class="nav-item ms-lg-2">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            <div class="dropdown">
                                <a class="btn-secundario dropdown-toggle d-inline-flex align-items-center"
                                   href="#" role="button" data-bs-toggle="dropdown">
                                    <i class="bi bi-person-circle me-2"></i>@User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="border-radius:12px; min-width:190px;">
                                    <li>
                                        <a class="dropdown-item" asp-controller="Home" asp-action="Dashboard">
                                            <i class="bi bi-grid-1x2 me-2 text-primary"></i>Panel
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider" /></li>
                                    <li>
                                        <a class="dropdown-item text-danger"
                                           asp-controller="Usuario" asp-action="Logout">
                                            <i class="bi bi-box-arrow-right me-2"></i>Cerrar sesión
                                        </a>
                                    </li>
                                </ul>
                            </div>
                        }
                        else
                        {
                            <a class="btn-primario" asp-controller="Usuario" asp-action="Login">
                                <i class="bi bi-lock me-1"></i>Acceso Administrativo
                            </a>
                        }
                    </li>
                </ul>
            </div>
        </div>
    </nav>

    <main>
        @RenderBody()
    </main>

    <footer class="footer-aategre">
        <div class="container">
            <div class="row g-4">
                <div class="col-lg-4 col-md-6">
                    <div class="footer-logo">
                        <img src="~/images/logo AATEGRE.png" alt="AATEGRE Centro Diurno" />
                    </div>
                    <span class="footer-nombre">AATEGRE Centro Diurno</span>
                    <p class="footer-slogan">Cuidado integral con calidez humana para nuestros adultos mayores.</p>
                    <div class="mt-3 d-flex gap-2 flex-wrap">
                        <a href="#" class="rrss-btn fb"><i class="bi bi-facebook"></i> Facebook</a>
                        <a href="#" class="rrss-btn ig"><i class="bi bi-instagram"></i> Instagram</a>
                    </div>
                </div>
                <div class="col-lg-2 col-md-6 col-sm-6">
                    <h6 class="footer-titulo">Navegación</h6>
                    <ul class="footer-links">
                        <li><a asp-controller="Home" asp-action="Index"><i class="bi bi-chevron-right"></i>Inicio</a></li>
                        <li><a asp-controller="Home" asp-action="QuienesSomos"><i class="bi bi-chevron-right"></i>Quiénes Somos</a></li>
                        <li><a asp-controller="Imagen" asp-action="Galeria"><i class="bi bi-chevron-right"></i>Actividades</a></li>
                        <li><a asp-controller="Home" asp-action="Contacto"><i class="bi bi-chevron-right"></i>Contacto</a></li>
                    </ul>
                </div>
                <div class="col-lg-2 col-md-6 col-sm-6">
                    <h6 class="footer-titulo">Servicios</h6>
                    <ul class="footer-links">
                        <li><a href="#"><i class="bi bi-chevron-right"></i>Atención médica</a></li>
                        <li><a href="#"><i class="bi bi-chevron-right"></i>Terapia física</a></li>
                        <li><a href="#"><i class="bi bi-chevron-right"></i>Actividades recreativas</a></li>
                        <li><a href="#"><i class="bi bi-chevron-right"></i>Nutrición</a></li>
                    </ul>
                </div>
                <div class="col-lg-4 col-md-6">
                    <h6 class="footer-titulo">Información de Contacto</h6>
                    <div class="footer-dato"><i class="bi bi-geo-alt-fill"></i><span>Grecia, Alajuela, Costa Rica</span></div>
                    <div class="footer-dato"><i class="bi bi-telephone-fill"></i><span>+506 2494-XXXX</span></div>
                    <div class="footer-dato"><i class="bi bi-envelope-fill"></i><span>info@@aategre.cr</span></div>
                    <div class="footer-dato"><i class="bi bi-clock-fill"></i><span>Lunes a Viernes · 7:00 a.m. – 4:00 p.m.</span></div>
                </div>
            </div>
        </div>
        <div class="footer-bottom">
            <div class="container">
                <p class="mb-0">&copy; @DateTime.Now.Year AATEGRE Centro Diurno — Todos los derechos reservados.</p>
            </div>
        </div>
    </footer>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>