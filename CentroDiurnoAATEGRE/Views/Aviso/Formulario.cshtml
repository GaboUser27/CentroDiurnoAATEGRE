@using CentroDiurnoAATEGRE.Application.DTOs
@model AvisoDTO
@{
    bool esEdicion = Model.IdAviso > 0;
    ViewData["Title"] = esEdicion ? "Editar Aviso" : "Nuevo Aviso";
}

<div class="panel-header">
    <div class="container">
        <div class="d-flex align-items-center gap-3">
            <a asp-action="Index" class="btn-secundario"
               style="border-color:rgba(255,255,255,0.5);color:white;">
                <i class="bi bi-arrow-left"></i>
            </a>
            <h1 class="mb-0">
                <i class="bi bi-@(esEdicion ? "pencil-square" : "plus-circle") me-2"></i>@ViewData["Title"]
            </h1>
        </div>
    </div>
</div>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-7">
            <div class="bg-white rounded-3 shadow-sm p-4 p-md-5">
                <form method="post" asp-action="@(esEdicion ? "Editar" : "Crear")"
                      asp-route-id="@Model.IdAviso" class="form-admin">
                    @Html.AntiForgeryToken()
                    <div class="mb-4">
                        <label class="form-label" asp-for="Titulo">
                            <i class="bi bi-fonts me-1"></i>Título del aviso
                        </label>
                        <input asp-for="Titulo" class="form-control"
                               placeholder="Ej: Actividades de Semana Santa" maxlength="150" required />
                        <span asp-validation-for="Titulo" class="text-danger small"></span>
                    </div>
                    <div class="mb-4">
                        <label class="form-label" asp-for="Contenido">
                            <i class="bi bi-text-paragraph me-1"></i>Contenido del aviso
                        </label>
                        <textarea asp-for="Contenido" class="form-control" rows="5"
                                  placeholder="Describa el aviso con todos los detalles..." required></textarea>
                        <span asp-validation-for="Contenido" class="text-danger small"></span>
                    </div>
                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label class="form-label" asp-for="FechaPublicacion">
                                <i class="bi bi-calendar-plus me-1"></i>Fecha de publicación
                            </label>
                            <input asp-for="FechaPublicacion" type="date" class="form-control" required />
                            <span asp-validation-for="FechaPublicacion" class="text-danger small"></span>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label" asp-for="FechaExpiracion">
                                <i class="bi bi-calendar-x me-1"></i>Fecha de expiración
                                <span class="text-muted fw-normal">(opcional)</span>
                            </label>
                            <input asp-for="FechaExpiracion" type="date" class="form-control" />
                            <span asp-validation-for="FechaExpiracion" class="text-danger small"></span>
                        </div>
                    </div>
                    <div class="mb-4">
                        <div class="form-check form-switch">
                            <input asp-for="Activo" class="form-check-input" type="checkbox" role="switch"
                                   style="width:2.5em;height:1.5em;" />
                            <label class="form-check-label ms-2 fw-semibold" asp-for="Activo">
                                Aviso activo (visible en el sitio)
                            </label>
                        </div>
                    </div>
                    <div class="d-flex gap-3 justify-content-end">
                        <a asp-action="Index" class="btn-secundario">
                            <i class="bi bi-x-circle"></i>Cancelar
                        </a>
                        <button type="submit" class="btn-primario">
                            <i class="bi bi-@(esEdicion ? "check-circle" : "plus-lg")"></i>
                            @(esEdicion ? "Guardar cambios" : "Crear aviso")
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>